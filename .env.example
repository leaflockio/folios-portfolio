# Folios Portfolio Environment Variables
# Copy this file to .env.local and fill in your values
# Build will fail if required variables are missing

# Required: Your name
FP_FIRST_NAME=
FP_LAST_NAME=

# Required: Path to profile.json
#
# Option 1 - Local path (starts with /):
#   The file must exist inside this project's public/ folder.
#   Example: FP_PROFILE_PATH=/data/profile.json
#            → File location: <project-root>/public/data/profile.json
#            → Vite serves public/ contents at the root URL
#            → At runtime, fetch('/data/profile.json') retrieves it
#
# Option 2 - External URL (starts with http:// or https://):
#   The file is fetched from the remote server at runtime.
#   Example: FP_PROFILE_PATH=https://example.com/api/profile.json
#
FP_PROFILE_PATH=/data/profile.json

# Optional: Contact info for error page
FP_EMAIL=
FP_PHONE_COUNTRY_CODE=
FP_PHONE_NUMBER=

# Optional: Show contact info on error page (defaults to false)
FP_SHOW_CONTACT_ON_ERROR=false
